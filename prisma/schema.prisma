// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model EditHistory {
  id             Int      @id @default(autoincrement())
  shop           String
  resourceType   String   @default("product") // "product" | "collection"
  productId      String   // generic resource GID; column name is legacy
  productTitle   String   // generic resource title; column name is legacy
  oldTitle       String?
  newTitle       String?
  oldDescription String?
  newDescription String?
  editedAt       DateTime @default(now())

  @@index([shop, editedAt])
  @@index([shop, resourceType, editedAt])
}

model BulkJob {
  id           String       @id @default(cuid())
  shop         String
  resourceType String       @default("product") // "product" | "collection"
  fileName     String
  totalRows    Int
  successRows  Int          @default(0)
  failedRows   Int          @default(0)
  status       String       @default("pending")
  createdAt    DateTime     @default(now())
  completedAt  DateTime?
  rows         BulkJobRow[]

  @@index([shop, createdAt])
  @@index([shop, resourceType, createdAt])
}

model BulkJobRow {
  id              String    @id @default(cuid())
  jobId           String
  job             BulkJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowNumber       Int
  productUrl      String
  metaTitle       String
  metaDescription String
  productId       String?
  productTitle    String?
  status          String    @default("pending")
  errorMessage    String?
  processedAt     DateTime?

  @@index([jobId, rowNumber])
}
